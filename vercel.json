{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "index.js" }
  ],
  "crons": [
    {
      "path": "/cron/admin-report",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/cron/donation-reminder",
      "schedule": "*/10 * * * *"
    }
  ]
}